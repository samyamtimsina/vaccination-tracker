generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        Int                 @id @default(autoincrement())
  name                      String
  email                     String              @unique
  passwordHash              String
  role                      UserRole 
  wardId                    Int?
  phoneNumber               String 
  status                    UserStatus @default(PENDING)
  Child                     Child[]
  Mother                    Mother[]
  createdVaccinationRecords VaccinationRecord[] @relation(name: "CreatedByVaccination")
  administeredVaccinations  VaccinationRecord[] @relation(name: "AdministeredByVaccination")
  AuditLogs                 AuditLog[]
  createdWeightRecords      WeightRecord[]      @relation(name: "CreatedByWeight")
  administeredWeightRecords WeightRecord[]      @relation(name: "AdministeredByWeight")
  verifiedChildren          Child[]             @relation(name: "VerifiedBy")
  createdTDDoses            TDDose[]
  administeredTDDoses       TDDose[]            @relation("AdministeredByTDDose")
  RefreshTokens             RefreshToken[]
  otps                      Otp[]
  vaccineScheduleVersions   VaccineScheduleVersion[]
  createdAt                 DateTime @default(now())
}
enum UserRole {
  SUPER_ADMIN
  ADMIN
  WARD_OFFICER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  device    String? // optional: track device/browser
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Otp {
  id          Int      @id @default(autoincrement())
  otpCode     String   // The hashed OTP code
  expiresAt   DateTime // The time when the OTP becomes invalid
  createdAt   DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Child {
  id                        String              @id @default(uuid())
  sewaDartaNumber           Int                 @unique @default(autoincrement())
  fullName                  String
  wardNumber                Int
  casteCode                 Int
  gender                    String
  parentName                String
  tole                      String
  phoneNumber               String
  email                     String?
  birthDate                 DateTime
  purnaKhop                 Boolean             @default(false)
  remarks                   String?
  createdById               Int
  createdBy                 User                @relation(fields: [createdById], references: [id])
  verifiedById              Int?
  verifiedBy                User?               @relation(name: "VerifiedBy", fields: [verifiedById], references: [id])
  vaccinations              VaccinationRecord[]
  dueVaccines               ChildDueVaccine[] 
  createdAt                 DateTime            @default(now())
  NotificationLog           NotificationLog[]
  isFromOtherMunicipality   Boolean             @default(false)
  weightRecords             WeightRecord[]

  // --- Optimized Indexes (NEW) ---
  // Composite: For filtering children by Ward and registration date (Analytics Trends)
  @@index([wardNumber, createdAt]) 
  // Existing indexes:
  @@index([wardNumber])
  @@index([phoneNumber])
  @@index([fullName])        
  @@index([parentName])      
  @@index([birthDate])       
  @@index([createdAt])       
}

model Mother {
  id                        String    @id @default(uuid())
  sewaDartaNumber           Int       @unique @default(autoincrement())
  name                      String
  casteCode                 Int
  dateOfBirth               DateTime
  phoneNumber               String
  tole                      String
  wardNumber                Int
  pregnancyCount            Int
  previousTDTakenCount      Int
  remarks                   String?
  createdAt                 DateTime  @default(now())
  createdById               Int
  createdBy                 User      @relation(fields: [createdById], references: [id])
  isFromOtherMunicipality   Boolean   @default(false)
  NotificationLog           NotificationLog[]
  tdDoses                   TDDose[]

  // --- Optimized Indexes (NEW) ---
  // Composite: For filtering mother registrations by Ward and Time (Analytics)
  @@index([wardNumber, createdAt]) 
  // Existing indexes:
  @@index([sewaDartaNumber])
  @@index([name])
  @@index([wardNumber])
  @@index([phoneNumber])
  @@index([createdById])
  @@index([createdAt])
}

model TDDose {
  id                        String    @id @default(uuid())
  doseNumber                Int       // To identify if it's the 1st, 2nd, or 2nd+ dose
  dateGiven                 DateTime
  remarks                   String?
  motherId                  String
  mother                    Mother    @relation(fields: [motherId], references: [id])
  createdAt                 DateTime  @default(now())
  createdById               Int
  createdBy                 User      @relation(fields: [createdById], references: [id])
  administeredById          Int
  administeredBy            User      @relation("AdministeredByTDDose", fields: [administeredById], references: [id])
}

model VaccinationRecord {
  id                String      @id @default(uuid())
  citizenId         String      // This refers to Child.id
  vaccineTypeId     Int
  vaccineType       VaccineType @relation(fields: [vaccineTypeId], references: [id])
  doseNumber        Int
  dateGiven         DateTime
  isComplete        Boolean
  remarks           String?
  customVaccineName String?
  type              String      @default("routine")
  child             Child       @relation(fields: [citizenId], references: [id])
  createdById       Int
  createdBy         User        @relation(name: "CreatedByVaccination", fields: [createdById], references: [id])
  administeredById  Int?
  administeredBy    User?       @relation(name: "AdministeredByVaccination", fields: [administeredById], references: [id])

  isExternallyAdministered Boolean @default(false)
  externalAdministeredBy   String?
  createdAt         DateTime    @default(now())
  wardOfVaccination Int

  // --- Optimized Composite Indexes (NEW) ---
  // PRIMARY ANALYTIC INDEX: Filters by ward AND date (Critical for seasonal/ward-based analytics)
  @@index([wardOfVaccination, dateGiven]) 
  // Composite: For querying all records of a specific vaccine type over time
  @@index([vaccineTypeId, dateGiven])
  // Existing indexes:
  @@index([dateGiven])
  @@index([vaccineTypeId])
  @@index([citizenId, dateGiven])
  @@index([wardOfVaccination])
  @@index([administeredById])
}

model VaccineType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doses     Dose[]
  dueVaccines ChildDueVaccine[]
  records   VaccinationRecord[]
}

model Dose {
  id                        Int      @id @default(autoincrement())
  vaccineTypeId             Int
  vaccineType               VaccineType @relation(fields: [vaccineTypeId], references: [id])
  doseNumber                Int

  recommendedAtDays         Float?
  recommendedAtWeeks        Float?
  recommendedAtMonths       Float?
  recommendedAtYears        Float?
  isBooster                 Boolean   @default(false)
  isPrimary                 Boolean   @default(true)
  maxAgeDays                Float?
  maxAgeWeeks               Float?
  maxAgeMonths              Float?
  maxAgeYears               Float?

  requiredGender            String?   
  minSchoolClass            Int?
  maxSchoolClass            Int?
  minBirthYear              Int?      
  otherCriteria             Json?
  scheduleVersionId         Int @default(1)
  scheduleVersion           VaccineScheduleVersion @relation(fields: [scheduleVersionId], references: [id])
  @@unique([vaccineTypeId, doseNumber, scheduleVersionId])
}

model VaccineScheduleVersion {
  id                    Int      @id @default(autoincrement())
  lastModifiedAt        DateTime @updatedAt
  lastModifiedBy        Int?
  user                  User?    @relation(fields: [lastModifiedBy], references: [id])
  doses                 Dose[]
  copiedFromVersionId   Int?
  copiedFromVersion     VaccineScheduleVersion?    @relation("CopyOfSchedule", fields: [copiedFromVersionId], references: [id], onDelete: SetNull)
  subsequentVersions    VaccineScheduleVersion[]   @relation("CopyOfSchedule")
}

model ChildDueVaccine {
  id               String      @id @default(uuid())
  childId          String
  child            Child       @relation(fields: [childId], references: [id])
  vaccineTypeId    Int
  vaccineType      VaccineType @relation(fields: [vaccineTypeId], references: [id])
  doseNumber       Int
  dueDate          DateTime
  previousDueDate  DateTime?
  isCompleted      Boolean     @default(false)
  notificationSent Boolean     @default(false)
  correctiveSent   Boolean     @default(false)
  createdAt        DateTime    @default(now())
  scheduleVersion  Int         @default(1)
  catchUpLocked    Boolean     @default(false)
  isCatchUp        Boolean     @default(false)

  // --- Optimized Composite Indexes ---
  // Composite: Crucial for fast due date checks and transactional updates
  @@index([childId, dueDate]) 
  // Existing indexes (kept):
  @@index([dueDate, isCompleted, notificationSent])
  @@index([childId, isCompleted])
  @@index([childId, vaccineTypeId, doseNumber])
}

model NotificationLog {
  id                Int      @id @default(autoincrement())
  childId           String?
  motherId          String?
  message           String
  sentAt            DateTime @default(now())
  child             Child?   @relation(fields: [childId], references: [id])
  mother            Mother?  @relation(fields: [motherId], references: [id])

  // --- New Indexes for Outreach Analytics ---
  @@index([motherId, sentAt]) // To link notifications to mother responses by time
  @@index([childId, sentAt])  // To link notifications to child responses by time
}

model AuditLog {
  id                        Int       @id @default(autoincrement())
  userId                    Int
  action                    String
  meta                      Json?
  createdAt                 DateTime  @default(now())
  user                      User      @relation(fields: [userId], references: [id])
}

model CorrectionRequest {
  id                        Int       @id @default(autoincrement())
  vaccinationId             String
  requestedById             Int
  reason                    String
  status                    String    @default("pending")
  createdAt                 DateTime  @default(now())
  processedById             Int?
  processedAt               DateTime?
}

model Certificate {
  id                        Int       @id @default(autoincrement())
  childId                   String
  issuedById                Int
  issuedAt                  DateTime  @default(now())
  token                     String    @unique
  pdfPath                   String?
}

model WeightRecord {
  id                String   @id @default(uuid())
  date              DateTime
  weight            Float
  child             Child    @relation(fields: [childId], references: [id])
  childId           String
  createdById       Int
  createdBy         User     @relation(name: "CreatedByWeight", fields: [createdById], references: [id])
  administeredById  Int?
  administeredBy    User?    @relation(name: "AdministeredByWeight", fields: [administeredById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  wardOfVaccination Int

  @@index([childId, date])
  @@index([wardOfVaccination])
}

/// Tracks when each analytics domain was last updated
model AnalyticsMeta {
  domain                   String   @id
  lastProcessedTimestamptz DateTime
}

/// Cached child-immunization analytics
model ChildAnalyticsFact {
  id                     Int      @id @default(autoincrement())
  day                    DateTime
  ward                   Int
  vaccineTypeId          Int?
  doseNumber             Int?
  gender                 String?
  ageGroup               String?
  isExternal             Boolean  @default(false)

  totalRegisteredChildren Int     @default(0)
  vaccinatedChildren       Int     @default(0)
  zeroDoseChildren         Int     @default(0)
  dueToday                 Int     @default(0)
  overdue                  Int     @default(0)
  upcomingDue              Int     @default(0)
  onTime                   Int     @default(0)
  late                     Int     @default(0)
  dropoutFirstLast         Int     @default(0)
  dropoutRate              Float   @default(0)

  @@index([day])
  @@index([ward])
  @@index([vaccineTypeId])
  @@index([ageGroup])
}

/// Cached maternal-immunization analytics
model MotherAnalyticsFact {
  id                     Int      @id @default(autoincrement())
  day                    DateTime
  ward                   Int
  ageGroup               String?

  totalRegisteredMothers Int     @default(0)
  td1Given               Int     @default(0)
  td2Given               Int     @default(0)
  td2plusGiven           Int     @default(0)
  tdDropoutFirstLast     Int     @default(0)
  tdDropoutRate          Float   @default(0)
  td2OnTime              Int     @default(0)
  td2Late                Int     @default(0)

  @@index([day])
  @@index([ward])
}

/// Cached growth / nutrition analytics
model GrowthAnalyticsFact {
  id                       Int      @id @default(autoincrement())
  day                      DateTime
  ward                     Int
  ageGroup                 String?
  gender                   String?

  underweightCount          Int     @default(0)
  severelyUnderweightCount  Int     @default(0)
  normalWeightCount         Int     @default(0)
  overweightCount           Int     @default(0)
  avgWeight                 Float   @default(0)
  recordsCount              Int     @default(0)

  @@index([day])
  @@index([ward])
  @@unique([day, ward, gender, ageGroup], name: "day_ward_gender_ageGroup")

}
