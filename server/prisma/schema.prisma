generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id                        Int                 @id @default(autoincrement())
  name                      String
  email                     String              @unique
  passwordHash              String
  role                      UserRole 
  wardId                    Int?
  phoneNumber               String 
  status                    UserStatus @default(PENDING)
  Child                     Child[]
  Mother                    Mother[]
  createdVaccinationRecords VaccinationRecord[] @relation(name: "CreatedByVaccination")
  administeredVaccinations  VaccinationRecord[] @relation(name: "AdministeredByVaccination")
  AuditLogs                 AuditLog[]
  createdWeightRecords      WeightRecord[]      @relation(name: "CreatedByWeight")
  administeredWeightRecords WeightRecord[]      @relation(name: "AdministeredByWeight")
  verifiedChildren          Child[]             @relation(name: "VerifiedBy")
  createdTDDoses            TDDose[]
  administeredTDDoses       TDDose[]            @relation("AdministeredByTDDose")
  RefreshTokens             RefreshToken[]
  otps                      Otp[]
  vaccineScheduleVersions   VaccineScheduleVersion[]
  createdAt                 DateTime @default(now())
}
enum UserRole {
  SUPER_ADMIN
  ADMIN
  WARD_OFFICER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  device    String? // optional: track device/browser
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Otp {
  id          Int      @id @default(autoincrement())
  otpCode     String   // The hashed OTP code
  expiresAt   DateTime // The time when the OTP becomes invalid
  createdAt   DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Child {
  id                        String              @id @default(uuid())
  sewaDartaNumber           Int                 @unique @default(autoincrement())
  fullName                  String
  wardNumber                Int
  casteCode                 Int
  gender                    String
  parentName                String
  tole                      String
  phoneNumber               String
  email                     String?
  birthDate                 DateTime
  purnaKhop                 Boolean             @default(false)
  remarks                   String?
  createdById               Int
  createdBy                 User                @relation(fields: [createdById], references: [id])
  verifiedById              Int?
  verifiedBy                User?               @relation(name: "VerifiedBy", fields: [verifiedById], references: [id])
  vaccinations              VaccinationRecord[]
  dueVaccines               ChildDueVaccine[] 
  createdAt                 DateTime            @default(now())
  NotificationLog           NotificationLog[]
  isFromOtherMunicipality   Boolean             @default(false)
  weightRecords             WeightRecord[]
  updatedAt DateTime @updatedAt

  @@index([wardNumber, createdAt]) 
  @@index([wardNumber])
  @@index([phoneNumber])
  @@index([fullName])        
  @@index([parentName])      
  @@index([birthDate])       
  @@index([createdAt])       
  @@index([updatedAt])
}

model Mother {
  id                        String    @id @default(uuid())
  sewaDartaNumber           Int       @unique @default(autoincrement())
  name                      String
  casteCode                 Int
  dateOfBirth               DateTime
  phoneNumber               String
  tole                      String
  wardNumber                Int
  pregnancyCount            Int
  previousTDTakenCount      Int
  remarks                   String?
  createdAt                 DateTime  @default(now())
  createdById               Int
  createdBy                 User      @relation(fields: [createdById], references: [id])
  isFromOtherMunicipality   Boolean   @default(false)
  NotificationLog           NotificationLog[]
  tdDoses                   TDDose[]
  updatedAt DateTime @updatedAt

  @@index([wardNumber, createdAt]) 
  @@index([sewaDartaNumber])
  @@index([name])
  @@index([wardNumber])
  @@index([phoneNumber])
  @@index([createdById])
  @@index([createdAt])
  @@index([updatedAt])
}

model TDDose {
  id                        String    @id @default(uuid())
  doseNumber                Int       // To identify if it's the 1st, 2nd, or 2nd+ dose
  dateGiven                 DateTime
  remarks                   String?
  motherId                  String
  mother                    Mother    @relation(fields: [motherId], references: [id])
  createdAt                 DateTime  @default(now())
  createdById               Int
  createdBy                 User      @relation(fields: [createdById], references: [id])
  administeredById          Int
  administeredBy            User      @relation("AdministeredByTDDose", fields: [administeredById], references: [id])
  updatedAt DateTime @updatedAt
  @@index([updatedAt])

}

model VaccinationRecord {
  id                String      @id @default(uuid())
  citizenId         String      // This refers to Child.id
  vaccineTypeId     Int
  vaccineType       VaccineType @relation(fields: [vaccineTypeId], references: [id])
  doseNumber        Int
  dateGiven         DateTime
  isComplete        Boolean
  remarks           String?
  customVaccineName String?
  type              String      @default("routine")
  child             Child       @relation(fields: [citizenId], references: [id])
  createdById       Int
  createdBy         User        @relation(name: "CreatedByVaccination", fields: [createdById], references: [id])
  administeredById  Int?
  administeredBy    User?       @relation(name: "AdministeredByVaccination", fields: [administeredById], references: [id])

  isExternallyAdministered Boolean @default(false)
  externalAdministeredBy   String?
  createdAt         DateTime    @default(now())
  wardOfVaccination Int
  updatedAt DateTime @updatedAt


  @@index([wardOfVaccination, dateGiven]) 
  @@index([vaccineTypeId, dateGiven])
  @@index([dateGiven])
  @@index([vaccineTypeId])
  @@index([citizenId, dateGiven])
  @@index([wardOfVaccination])
  @@index([administeredById])
  @@index([updatedAt])
}

model VaccineType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doses     Dose[]
  dueVaccines ChildDueVaccine[]
  records   VaccinationRecord[]
  monthlyDropoutFacts       ChildMonthlyDropoutFact[]
  childRollingDropoutFact   ChildRollingDropoutFact[]
  monthlyVaccineInventory MonthlyVaccineInventory[]
  monthlyDoseCount MonthlyDoseCount[]
}

model Dose {
  id                        Int      @id @default(autoincrement())
  vaccineTypeId             Int
  vaccineType               VaccineType @relation(fields: [vaccineTypeId], references: [id])
  doseNumber                Int

  recommendedAtDays         Float?
  recommendedAtWeeks        Float?
  recommendedAtMonths       Float?
  recommendedAtYears        Float?
  isBooster                 Boolean   @default(false)
  isPrimary                 Boolean   @default(true)
  maxAgeDays                Float?
  maxAgeWeeks               Float?
  maxAgeMonths              Float?
  maxAgeYears               Float?

  requiredGender            String?   
  minSchoolClass            Int?
  maxSchoolClass            Int?
  minBirthYear              Int?      
  otherCriteria             Json?
  scheduleVersionId         Int @default(1)
  scheduleVersion           VaccineScheduleVersion @relation(fields: [scheduleVersionId], references: [id])
  @@unique([vaccineTypeId, doseNumber, scheduleVersionId])
}

model VaccineScheduleVersion {
  id                    Int      @id @default(autoincrement())
  lastModifiedAt        DateTime @updatedAt
  lastModifiedBy        Int?
  user                  User?    @relation(fields: [lastModifiedBy], references: [id])
  doses                 Dose[]
  copiedFromVersionId   Int?
  copiedFromVersion     VaccineScheduleVersion?    @relation("CopyOfSchedule", fields: [copiedFromVersionId], references: [id], onDelete: SetNull)
  subsequentVersions    VaccineScheduleVersion[]   @relation("CopyOfSchedule")
}

model ChildDueVaccine {
  id               String      @id @default(uuid())
  childId          String
  child            Child       @relation(fields: [childId], references: [id])
  vaccineTypeId    Int
  vaccineType      VaccineType @relation(fields: [vaccineTypeId], references: [id])
  doseNumber       Int
  dueDate          DateTime
  previousDueDate  DateTime?
  isCompleted      Boolean     @default(false)
  notificationSent Boolean     @default(false)
  correctiveSent   Boolean     @default(false)
  createdAt        DateTime    @default(now())
  scheduleVersion  Int         @default(1)
  catchUpLocked    Boolean     @default(false)
  isCatchUp        Boolean     @default(false)

  @@index([childId, dueDate]) 
  @@index([dueDate, isCompleted, notificationSent])
  @@index([childId, isCompleted])
  @@index([childId, vaccineTypeId, doseNumber])
}

model NotificationLog {
  id                Int      @id @default(autoincrement())
  childId           String?
  motherId          String?
  message           String
  sentAt            DateTime @default(now())
  child             Child?   @relation(fields: [childId], references: [id])
  mother            Mother?  @relation(fields: [motherId], references: [id])

  // --- New Indexes for Outreach Analytics ---
  @@index([motherId, sentAt]) // To link notifications to mother responses by time
  @@index([childId, sentAt])  // To link notifications to child responses by time
}

model AuditLog {
  id                        Int       @id @default(autoincrement())
  userId                    Int
  action                    String
  meta                      Json?
  createdAt                 DateTime  @default(now())
  user                      User      @relation(fields: [userId], references: [id])
}

model CorrectionRequest {
  id                        Int       @id @default(autoincrement())
  vaccinationId             String
  requestedById             Int
  reason                    String
  status                    String    @default("pending")
  createdAt                 DateTime  @default(now())
  processedById             Int?
  processedAt               DateTime?
}

model Certificate {
  id                        Int       @id @default(autoincrement())
  childId                   String
  issuedById                Int
  issuedAt                  DateTime  @default(now())
  token                     String    @unique
  pdfPath                   String?
}

model WeightRecord {
  id                String   @id @default(uuid())
  date              DateTime
  weight            Float
  child             Child    @relation(fields: [childId], references: [id])
  childId           String
  createdById       Int
  createdBy         User     @relation(name: "CreatedByWeight", fields: [createdById], references: [id])
  administeredById  Int?
  administeredBy    User?    @relation(name: "AdministeredByWeight", fields: [administeredById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  wardOfVaccination Int

  @@index([childId, date])
  @@index([wardOfVaccination])
  @@index([updatedAt])
}

model AnalyticsMeta {
  id                    Int      @id @default(autoincrement())
  lastProcessedChild    DateTime @default(now())
  lastProcessedMother   DateTime @default(now())
  lastProcessedGrowth   DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([id])
}

model ChildAnalyticsFact {
  id                       Int      @id @default(autoincrement())
  day                      DateTime @db.Date
  ward                     Int
  vaccineTypeId            Int?
  doseNumber               Int      @default(0)
  gender                   String?
  ageGroup                 String?
  casteCode                Int
  totalRegisteredChildren  Int      @default(0)
  vaccinatedChildren       Int      @default(0)
  zeroDoseChildren         Int      @default(0)
  dueToday                 Int      @default(0)
  overdue                  Int      @default(0)
  onTime                   Int      @default(0)
  late                     Int      @default(0)
  dropoutRate              Float?   @default(0)

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([day, ward, vaccineTypeId, doseNumber, gender, ageGroup, casteCode])
  @@index([day])
  @@index([ward])
  @@index([vaccineTypeId])
  @@index([casteCode])
  @@index([gender])
  @@index([ageGroup])
}
model MotherAnalyticsFact {
  id                      Int      @id @default(autoincrement())
  day                     DateTime @db.Date
  ward                    Int
  doseNumber              Int      @default(0)
  casteCode               Int
  totalRegisteredMothers  Int      @default(0)
  tdDosesGiven            Int      @default(0)
  mothersWithZeroTD       Int      @default(0)
  mothersWithFullTD       Int      @default(0)
  dueToday                Int      @default(0)
  overdue                 Int      @default(0)
  coverage                Float?   @default(0)
  dropoutRate             Float?   @default(0)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([day, ward, doseNumber, casteCode])
  @@index([day])
  @@index([ward])
  @@index([casteCode])
}


model GrowthAnalyticsFact {
  id                       Int      @id @default(autoincrement())
  day                      DateTime @db.Date
  ward                     Int
  gender                   String?
  ageGroup                 String?
  casteCode                Int
  totalWeightRecords       Int      @default(0)
  avgWeightKg              Float?   @default(0)
  underweightCount         Int      @default(0)
  normalWeightCount        Int      @default(0)
  overweightCount          Int      @default(0)

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([day, ward, gender, ageGroup, casteCode])
  @@index([day])
  @@index([ward])
  @@index([casteCode])
  @@index([gender])
  @@index([ageGroup])
}
model ChildMonthlyDropoutFact {
  id                Int       @id @default(autoincrement())
  snapshotMonth     DateTime  @db.Date      // Start of the month (BS month)
  ward              Int
  vaccineTypeId     Int
  doseNumber        Int       @default(0)
  gender            String?   
  ageGroup          String?   
  casteCode         Int?
  
  totalDue          Int       @default(0)   // Children due this month
  totalCompleted    Int       @default(0)   // Children who completed within window
  dropoutCount      Int       @default(0)   // Missed within 30-day window

  dropoutRate       Float?    @default(0)   // Calculated as dropoutCount / totalDue * 100

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vaccineType       VaccineType @relation(fields: [vaccineTypeId], references: [id])

  @@unique([snapshotMonth, ward, vaccineTypeId, doseNumber, gender, ageGroup, casteCode])
  @@index([snapshotMonth])
  @@index([ward])
  @@index([vaccineTypeId])
  @@index([doseNumber])
}
// Add to your existing schema
model ChildRollingDropoutFact {
  id                Int       @id @default(autoincrement())
  snapshotMonth     DateTime  @db.Date      // Start of the month
  windowType        String    // '1M', '3M', '6M', '12M'
  ward              Int
  vaccineTypeId     Int
  doseNumber        Int       @default(0)
  gender            String?   
  ageGroup          String?   
  casteCode         Int?
  
  totalDue          Int       @default(0)
  totalCompleted    Int       @default(0)
  dropoutCount      Int       @default(0)
  dropoutRate       Float?    @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vaccineType       VaccineType @relation(fields: [vaccineTypeId], references: [id])

  @@unique([snapshotMonth, windowType, ward, vaccineTypeId, doseNumber, gender, ageGroup, casteCode])
  @@index([snapshotMonth])
  @@index([windowType])
  @@index([ward])
  @@index([vaccineTypeId])
}

// Add to your existing schema
model MonthlyVaccineInventory {
  id            Int       @id @default(autoincrement())
  snapshotMonth DateTime  @db.Date
  vaccineTypeId Int
  received      Int       @default(0)
  spent         Int       @default(0)
  opened        Int       @default(0)
  spoiled       Int       @default(0)
  returned      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vaccineType   VaccineType @relation(fields: [vaccineTypeId], references: [id])

  @@unique([snapshotMonth, vaccineTypeId])
  @@index([snapshotMonth])
  @@index([vaccineTypeId])
}

model MonthlyDoseCount {
  id            Int       @id @default(autoincrement())
  snapshotMonth DateTime  @db.Date
  vaccineTypeId Int
  doseNumber    Int
  countGiven    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vaccineType   VaccineType @relation(fields: [vaccineTypeId], references: [id])

  @@unique([snapshotMonth, vaccineTypeId, doseNumber])
  @@index([snapshotMonth])
  @@index([vaccineTypeId])
}

model MonthlySpecialFact {
  id              Int       @id @default(autoincrement())
  snapshotMonth   DateTime  @db.Date
  fullWithin23m   Int       @default(0)
  started24To59m  Int       @default(0)
  aefiNormal      Int       @default(0)
  aefiSerious     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([snapshotMonth])
  @@index([snapshotMonth])
}