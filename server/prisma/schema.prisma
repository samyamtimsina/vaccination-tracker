// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  name              String
  email             String              @unique
  passwordHash      String
  role              String
  wardId            Int?
  Child             Child[]
  Mother            Mother[]
  VaccinationRecord VaccinationRecord[]
AuditLogs    AuditLog[] 
}

model Child {
  id                      String              @id @default(uuid())
  sewaDartaNumber         Int
  fullName                String // Combined full name (first + last)
  wardNumber              Int
  casteCode               Int
  gender                  String
  parentName              String
  tole                    String
  phoneNumber             String
  birthDate               DateTime
  purnaKhop               Boolean             @default(false)
  remarks                 String?
  createdById             Int
  createdBy               User                @relation(fields: [createdById], references: [id])
  vaccinations            VaccinationRecord[]
  createdAt               DateTime            @default(now())
  NotificationLog         NotificationLog[]
  isFromOtherMunicipality Boolean             @default(false)
}

model Mother {
  id                      String    @id @default(uuid())
  sewaDartaNumber         Int
  name                    String
  casteCode               Int
  age                     Int
  phoneNumber             String
  tole                    String
  wardNumber              Int
  pregnancyCount          Int
  previousTDTakenCount    Int
  tdDose1                 DateTime?
  tdDose2                 DateTime?
  tdDose2Plus             DateTime?
  remarks                 String?
  createdAt               DateTime  @default(now())
  createdById             Int
  createdBy               User      @relation(fields: [createdById], references: [id])
  isFromOtherMunicipality Boolean   @default(false)
}

model VaccinationRecord {
  id                  String      @id @default(uuid())
  citizenId           String
  vaccineType         VaccineType
  doseNumber          Int
  dateGiven           DateTime
  isComplete          Boolean
  remarks             String?
  recommendedAtMonths Int
  customVaccineName   String? // keep optional for "OTHERS" type
  child               Child       @relation(fields: [citizenId], references: [id])
  createdById         Int
  createdBy           User        @relation(fields: [createdById], references: [id])
  createdAt           DateTime    @default(now())
}

enum VaccineType {
  BCG
  ROTA
  OPV
  fIPV
  PCV
  DPT_HepB_hib
  MR
  JE
  TCV
  HPV // Added HPV based on your React doses
}

model NotificationLog {
  id          Int         @id @default(autoincrement())
  citizenId   String
  vaccineType VaccineType
  doseNumber  Int
  sentAt      DateTime    @default(now())
  type        String // "due" or "oneWeekBefore"
  child       Child       @relation(fields: [citizenId], references: [id])
}
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String   // 'create_child', 'create_vaccination', 'generate_certificate', 'correction_request', etc.
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model CorrectionRequest {
  id              Int      @id @default(autoincrement())
  vaccinationId   String
  requestedById   Int
  reason          String
  status          String   @default("pending") // pending, approved, rejected
  createdAt       DateTime @default(now())
  processedById   Int?
  processedAt     DateTime?
}

model Certificate {
  id           Int      @id @default(autoincrement())
  childId      String
  issuedById   Int
  issuedAt     DateTime @default(now())
  token        String   @unique // UUID or secure token
  pdfPath      String?  // optional if you store pdfs
}
