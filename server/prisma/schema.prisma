// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int     @id @default(autoincrement())
  name         String
  email        String  @unique
  passwordHash String
  role         String
  wardId       Int?
  Child        Child[]
}

model Child {
  id              String              @id @default(uuid())
  fullName        String // Combined full name (first + last)
  wardNumber      String
  casteCode       Int
  gender          String
  parentName      String
  tole            String
  phoneNumber     String
  birthDate       DateTime
  purnaKhop       Boolean             @default(false)
  remarks         String?
  createdById     Int
  createdBy       User                @relation(fields: [createdById], references: [id])
  vaccinations    VaccinationRecord[]
  createdAt       DateTime            @default(now())
  NotificationLog NotificationLog[]
}

model VaccinationRecord {
  id                  String      @id @default(uuid())
  citizenId           String
  vaccineType         VaccineType
  doseNumber          Int
  dateGiven           DateTime
  isComplete          Boolean
  remarks             String?
  recommendedAtMonths Int
  customVaccineName   String? // keep optional for "OTHERS" type
  child               Child       @relation(fields: [citizenId], references: [id])
}

enum VaccineType {
  BCG
  ROTA
  OPV
  fIPV
  PCV
  DPT_HepB_hib
  MR
  JE
  TCV
  HPV // Added HPV based on your React doses
  OTHERS
}

model NotificationLog {
  id          Int         @id @default(autoincrement())
  citizenId   String
  vaccineType VaccineType
  doseNumber  Int
  sentAt      DateTime    @default(now())
  type        String // "due" or "oneWeekBefore"
  child       Child       @relation(fields: [citizenId], references: [id])
}
